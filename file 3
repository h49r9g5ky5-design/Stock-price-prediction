import streamlit as st
import requests
import time
import pandas as pd
import matplotlib.pyplot as plt
from transformers import pipeline
import platform

# 🔒 [보안 설정] 코드 내에 직접 키를 적지 않고, 스트림릿 환경설정(secrets)에서 안전하게 불러옵니다.
# 로컬 테스트 시 프로젝트 폴더 안의 .streamlit/secrets.toml 파일을 참조합니다.
NAVER_CLIENT_ID = st.secrets["NAVER_CLIENT_ID"]
NAVER_CLIENT_SECRET = st.secrets["NAVER_CLIENT_SECRET"]

# 1. 시스템 OS별 폰트 설정을 통한 한글 깨짐 방지
if platform.system() == 'Windows':
    plt.rc('font', family='Malgun Gothic')
elif platform.system() == 'Darwin':  # Mac 환경
    plt.rc('font', family='AppleGothic')
plt.rc('axes', unicode_minus=False)  # 마이너스 기호 깨짐 방지


# 2. 검증된 공식 다국어 AI 감성 분석 모델 로드
@st.cache_resource
def load_sentiment_model():
    return pipeline("sentiment-analysis", model="Seethal/sentiment_analysis_generic_dataset")


sentiment_analyzer = load_sentiment_model()


# 3. 네이버 공식 API 기반 뉴스 수집 함수
def crawl_samsung_news_api():
    articles = []

    # API 호출을 위한 헤더 구성
    headers = {
        "X-Naver-Client-Id": NAVER_CLIENT_ID,
        "X-Naver-Client-Secret": NAVER_CLIENT_SECRET
    }

    # 왼쪽 영역 진행 상황 표시용 UI 컴포넌트
    progress_bar = st.progress(0)
    status_text = st.empty()

    # API 요청을 통해 한 번에 50개의 최신 삼성전자 뉴스 데이터를 호출
    url = "https://openapi.naver.com/v1/search/news.json?query=삼성전자&display=50&sort=date"

    try:
        time.sleep(2)  # 과도한 요청 방지를 위한 2초 대기 요구사항 준수
        response = requests.get(url, headers=headers, timeout=5)

        if response.status_code == 200:
            data = response.json()
            items = data.get('items', [])

            for idx, item in enumerate(items):
                # 뉴스 내용 중 가독성을 해치는 HTML 특수 태그 제거 처리
                title = item['title'].replace("<b>", "").replace("</b>", "").replace("&quot;", "")
                description = item['description'].replace("<b>", "").replace("</b>", "").replace("&quot;", "")

                # 분석 정확도를 높이기 위해 제목과 요약을 합쳐 본문 데이터로 활용
                full_content = f"{title} {description}"
                articles.append(full_content)

                # 실시간 진행 상황 및 누적 개수 화면 표시
                status_text.write(f"✅ 성공: [{idx + 1}/50] '{title[:20]}...' 수집 완료")
                progress_bar.progress((idx + 1) / len(items))

        else:
            status_text.write(f"❌ API 연결 실패 (상태코드: {response.status_code}) - 키 설정을 확인하세요.")

    except Exception as e:
        status_text.write(f"❌ 에러 발생: {str(e)}")

    return articles


# 4. AI 감성 분석 수행 함수
def analyze_sentiments(articles):
    results = {'긍정': 0, '부정': 0, '중립': 0}

    for text in articles:
        # 모델 입력 글자수(토큰) 제한 오류를 예방하기 위해 앞부분 400자 슬라이싱
        truncated_text = text[:400]
        try:
            prediction = sentiment_analyzer(truncated_text)[0]
            label = prediction['label'].upper()

            # 모델 아웃풋 라벨 매핑 패턴 분석 (POSITIVE / NEGATIVE / NEUTRAL)
            if 'POS' in label or 'LABEL_1' in label:
                results['긍정'] += 1
            elif 'NEG' in label or 'LABEL_0' in label:
                results['부정'] += 1
            else:
                results['중립'] += 1
        except Exception:
            # 예외 상황 발생 시 프로그램이 멈추지 않도록 중립으로 처리
            results['중립'] += 1

    return results


# --- Streamlit 좌우 2단 레이아웃 설정 ---
st.set_page_config(layout="wide")
st.title("📊 삼성 뉴스 기사 수집 및 AI 감성 분석 시스템")

col1, col2 = st.columns([1, 2])

# 버튼을 눌러 화면이 리프레시되어도 수집한 데이터를 유지하기 위한 세션 스테이트 초기화
if 'crawled_data' not in st.session_state:
    st.session_state.crawled_data = []

# [왼쪽 영역] 데이터 수집 컨트롤 및 실시간 진행률
with col1:
    st.header("1. 데이터 수집")
    if st.button("🚀 크롤링 시작"):
        with st.spinner("네이버 API를 통해 뉴스 데이터를 안전하게 가져오는 중..."):
            st.session_state.crawled_data = crawl_samsung_news_api()
            if st.session_state.crawled_data:
                st.success(f"총 {len(st.session_state.crawled_data)}개의 최신 뉴스 바인딩 완료!")

# [오른쪽 영역] AI 분석 실행 및 시각화 결과 출력
with col2:
    st.header("2. 감성 분석 결과")
    if st.button("🧠 감성 분석 시작"):
        if not st.session_state.crawled_data:
            st.error("먼저 왼쪽 영역에서 '크롤링 시작' 버튼을 눌러 데이터를 수집해 주세요.")
        else:
            with st.spinner("AI 모델이 수집된 뉴스의 감성을 분석 중입니다..."):
                # 감성 분석 처리
                analysis_results = analyze_sentiments(st.session_state.crawled_data)

                # 표(Dataframe) 형태로 대시보드에 노출
                df = pd.DataFrame(list(analysis_results.items()), columns=['감성', '건수'])
                st.dataframe(df.set_index('감성'))

                # 원그래프(Pie Chart) 시각화 처리
                fig, ax = plt.subplots(figsize=(6, 6))
                colors = ['#2ecc71', '#e74c3c', '#95a5a6']  # 긍정(녹색), 부정(적색), 중립(회색)

                ax.pie(
                    df['건수'],
                    labels=df['감성'],
                    autopct='%1.1f%%',
                    startangle=90,
                    colors=colors,
                    textprops={'fontsize': 12, 'weight': 'bold'}
                )
                ax.axis('equal')  # 파이 차트가 완전한 원을 유지하도록 설정
                plt.title("삼성 뉴스 기사 AI 감성 분포도", fontsize=16, pad=20, weight='bold')

                # Streamlit 화면에 차트 출력
                st.pyplot(fig)